APP_NAME=Jarvis Assistant Starter
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

LLM_PROVIDER=groq
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=300

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

BEDROCK_REGION=us-west-2
BEDROCK_MODEL_ID=nvidia.nemotron-nano-12b-v2
# Optional if you use a named local AWS profile.
# AWS_PROFILE_NAME=your-aws-profile

OPENAI_API_KEY=your_openai_api_key_here
REALTIME_MODEL=gpt-4o-mini-realtime-preview

DATABASE_URL=mysql+aiomysql://root:password@localhost:3306/jarvis
SQLITE_FALLBACK_URL=sqlite+aiosqlite:///./jarvis.db
ALLOW_SQLITE_FALLBACK=true
WHISPER_MODEL_SIZE=base
WHISPER_LANGUAGE=en
WHISPER_TASK=transcribe
# Set to cpu or cuda if you want to force a device. Leave commented to use defaults.
# WHISPER_DEVICE=cpu
VOICE_UNDERSTANDING_PROVIDER=legacy
EMOTION_MODEL_NAME=Dpngtm/wav2vec2-emotion-recognition
EMOTION_DEVICE=-1
SENSEVOICE_MODEL_NAME=iic/SenseVoiceSmall
SENSEVOICE_DEVICE=cpu
SENSEVOICE_LANGUAGE=auto
SENSEVOICE_USE_ITN=true
SENSEVOICE_VAD_MODEL=fsmn-vad
SENSEVOICE_CACHE_DIR=.cache/modelscope
SENSEVOICE_MAX_SINGLE_SEGMENT_TIME_MS=30000
SENSEVOICE_BATCH_SIZE_S=60
SENSEVOICE_MERGE_VAD=true
SENSEVOICE_MERGE_LENGTH_S=15
COQUI_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC
# Set to cpu or cuda if you want to force a device. Leave commented to use defaults.
# COQUI_DEVICE=cpu
AUDIO_OUTPUT_DIR=generated_audio
UPLOAD_DIR=uploads
MCP_SERVER_COMMAND=python
MCP_SERVER_SCRIPT=app/mcp_server.py
MCP_TIMEOUT_SECONDS=20
